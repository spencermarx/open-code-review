{
  "name": "cli",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/cli/src",
  "projectType": "application",
  "tags": ["scope:cli", "type:app"],
  "implicitDependencies": ["dashboard"],
  "targets": {
    "build:bundle": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist/index.js"],
      "dependsOn": ["^build"],
      "options": {
        "command": "node build.mjs",
        "cwd": "{projectRoot}"
      }
    },
    "build:copy-dashboard": {
      "executor": "nx:run-commands",
      "dependsOn": ["build:bundle"],
      "options": {
        "commands": [
          "rm -rf packages/cli/dist/dashboard",
          "cp -r packages/dashboard/dist packages/cli/dist/dashboard"
        ],
        "parallel": false,
        "cwd": "{workspaceRoot}"
      }
    },
    "build": {
      "dependsOn": ["build:bundle", "build:copy-dashboard"]
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsx packages/cli/src/index.ts",
        "cwd": "{workspaceRoot}"
      }
    },
    "init": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsx packages/cli/src/index.ts init",
        "cwd": "{workspaceRoot}"
      }
    },
    "progress": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsx packages/cli/src/index.ts progress",
        "cwd": "{workspaceRoot}"
      }
    },
    "update": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsx packages/cli/src/index.ts update",
        "cwd": "{workspaceRoot}"
      }
    },
    "doctor": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsx packages/cli/src/index.ts doctor",
        "cwd": "{workspaceRoot}"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run",
        "cwd": "{projectRoot}"
      }
    }
  }
}
