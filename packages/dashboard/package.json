{
  "name": "@open-code-review/dashboard",
  "version": "1.8.4",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx scripts/dev.ts",
    "dev:client": "vite",
    "dev:server": "tsx watch src/server/index.ts",
    "build": "pnpm build:client && pnpm build:server",
    "build:client": "vite build",
    "build:server": "esbuild src/server/index.ts --bundle --platform=node --format=esm --outfile=dist/server.js --external:sql.js --external:chokidar --external:socket.io --banner:js=\"import { createRequire as _cjsReq } from 'module'; const require = _cjsReq(import.meta.url);\"",
    "preview": "node dist/server.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@tanstack/react-query": "^5",
    "chokidar": "^4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "express": "^4",
    "lucide-react": "^0.577.0",
    "mermaid": "^11.12.3",
    "open": "^10",
    "react": "^19",
    "react-dom": "^19",
    "react-markdown": "^9",
    "react-router": "^7",
    "react-router-dom": "^7",
    "rehype-highlight": "^7",
    "remark-gfm": "^4",
    "socket.io": "^4.8",
    "socket.io-client": "^4.8",
    "sql.js": "^1.11",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@open-code-review/cli": "workspace:*",
    "@open-code-review/platform": "workspace:*",
    "@tailwindcss/vite": "^4.2.1",
    "@types/express": "^5.0.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sql.js": "^1.4.9",
    "@vitejs/plugin-react": "^5.1.4",
    "esbuild": "^0.24",
    "tailwindcss": "^4",
    "tsx": "^4.19.0",
    "typescript": "^5.7",
    "vite": "^6",
    "vitest": "^3"
  }
}
